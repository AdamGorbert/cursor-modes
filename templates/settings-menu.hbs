<div class="cursor-modes-body">
  <p class="hint">{{localize "CURSORMODES.MenuHint"}}</p>

  <fieldset>
    <legend>{{localize "CURSORMODES.HotspotLegend"}}</legend>
    <p class="hint">{{localize "CURSORMODES.HotspotHint"}}</p>
    <div class="form-group">
      <label>{{localize "CURSORMODES.HotspotX"}}</label>
      <div class="form-fields">
        <input type="number" name="hotspotX" value="{{hotspotX}}" min="0" max="128" step="1" />
      </div>
    </div>
    <div class="form-group">
      <label>{{localize "CURSORMODES.HotspotY"}}</label>
      <div class="form-fields">
        <input type="number" name="hotspotY" value="{{hotspotY}}" min="0" max="128" step="1" />
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{localize "CURSORMODES.ModesLegend"}}</legend>
    {{#each rows}}
    <div class="form-group cm-row">
      <label>{{this.label}}</label>
      <div class="form-fields">
        <input type="text" name="mode:{{this.key}}" value="{{this.value}}"
               placeholder="modules/cursor-modes/cursors/example.png" />
        <button type="button" class="icon" data-action="browse" data-key="{{this.key}}"
                title="{{localize 'CURSORMODES.Browse'}}">
          <i class="fa-solid fa-file-import"></i>
        </button>
      </div>
    </div>
    {{/each}}
  </fieldset>
</div>
